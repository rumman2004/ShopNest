{
  "name": "shopnest-backend",
  "version": "1.0.0",
  "description": "ShopNest POS System - Multi-tenant Point of Sale Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest --watchAll --verbose",
    "test:ci": "cross-env NODE_ENV=test jest --ci --coverage",
    "lint": "echo 'Linting not configured yet'",
    "generate-secrets": "node -e \"console.log('JWT_SECRET=' + require('crypto').randomBytes(64).toString('hex')); console.log('JWT_REFRESH_SECRET=' + require('crypto').randomBytes(64).toString('hex'));\"",
    "db:test": "node -e \"require('dotenv').config(); const db = require('./src/config/database'); db.testConnection().then(() => process.exit(0)).catch(() => process.exit(1));\"",
    "health": "curl -f http://localhost:5000/health || exit 1",
    "clean": "rm -rf node_modules package-lock.json && npm install"
  },
  "keywords": [
    "pos",
    "point-of-sale",
    "inventory",
    "sales",
    "retail",
    "multi-tenant",
    "express",
    "nodejs",
    "mysql",
    "api",
    "rest"
  ],
  "author": {
    "name": "Rumman Ahmed",
    "email": "rumman@example.com"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.20.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rummanahmed/shopnest-backend.git"
  },
  "bugs": {
    "url": "https://github.com/rummanahmed/shopnest-backend/issues"
  },
  "homepage": "https://github.com/rummanahmed/shopnest-backend#readme",
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/**/*.spec.js",
      "!node_modules/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js",
      "**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "tests/",
      "coverage/",
      "logs/",
      "uploads/"
    ],
    "delay": 1000,
    "env": {
      "NODE_ENV": "development"
    }
  }
}
